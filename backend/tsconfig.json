{
  "compilerOptions": {
    // strict type checking, no implicit `any`
    "strict": true,

    //  project uses ES modules ("type": "module" in package.json)
    "module": "ESNext",
    "moduleResolution": "bundler",

    // target modern Node.js
    "target": "ES2022",

    // output compiled JS to dist/ folder
    "outDir": "dist",
    "rootDir": "src",

    // lets you import CommonJS packages (express, cors, etc.) with `import x from "x"`
    "esModuleInterop": true,

    // skip type-checking node_modules .d.ts files (fixes resend/react type error)
    "skipLibCheck": true,

    // catches more bugs — like unused variables, unreachable code
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  // only check  source code, not node_modules
  "include": ["src"],
  "exclude": ["node_modules"]
}
